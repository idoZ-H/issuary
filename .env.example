# Copy to .env, fill in real values. Used by the deploy/tail CLI helpers
# documented in README.md — NOT loaded by the Worker at runtime.
#
# The Worker itself reads secrets from `wrangler secret put` (see DEPLOY.md
# step 4). Put the same values here AND upload them as Worker secrets.

# Required — Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAA...

# Required — webhook secret for Telegram → Worker. Any 32+ random bytes hex.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Required — Anthropic API key. The classifier runs on Opus 4.8; the closure
# DM runs on Sonnet 4.6 (see src/lib/ai.ts and src/pipeline/closure.ts).
ANTHROPIC_API_KEY=sk-ant-...

# Required — Gemini API key, used for voice transcription.
GEMINI_API_KEY=

# Required — GitHub App ID (numeric) from your App's settings page.
GITHUB_APP_ID=

# Required — GitHub App private key (PEM). Multiline; quote with single quotes.
# Get from your GitHub App settings → "Generate a private key".
GITHUB_APP_PRIVATE_KEY='-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----'

# Required — secret for GitHub webhooks. Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# Required — GCS service account JSON for media uploads. Quote with single quotes.
GCS_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# Required — GCS bucket name where audio/image attachments are stored.
GCS_BUCKET=your-feedback-media-bucket

# Required — your Telegram user ID (numeric). The bot DMs you when something
# notable happens (errors, rate limits, new client digests).
IDO_TG_USER_ID=

# Required — the Telegram chat ID for your "Ido inbox" channel (numeric,
# typically negative for channels: -100xxxxxxxxxx).
IDO_INBOX_CHAT_ID=

# Required only for local CLI use (the deploy helper script in README.md and
# `wrangler tail`). NOT read by the Worker at runtime.
# Create at https://dash.cloudflare.com/profile/api-tokens → "Edit Cloudflare
# Workers" template.
CLOUDFLARE_API_TOKEN=

# Optional — LangSmith tracing. Leave empty to disable.
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=feedback-bot
LANGSMITH_ORG_SLUG=

# Optional — powers the Workers AI neuron / KV-ops usage panel on
# /admin/index-status (read in src/admin/usage.ts). Without them the panel
# degrades gracefully. Upload both as Worker secrets if you want the panel:
# CLOUDFLARE_ACCOUNT_ID is your account id; CLOUDFLARE_ANALYTICS_TOKEN is an
# API token with Account Analytics read.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ANALYTICS_TOKEN=
